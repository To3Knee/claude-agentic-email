# claude-agentic-email channel config. Copy to ~/.claude/channels/agentic-email/.env
# (or run install.sh, which writes it for you). chmod 600 — it holds a secret.

# Your agentic-inbox worker base URL (no trailing slash).
AGENTIC_INBOX_BASE=https://inbox.example.com

# The mailbox this channel watches and sends from.
AGENTIC_INBOX_MAILBOX=assistant@example.com

# Display name on outbound mail (optional, default "Assistant").
AGENTIC_INBOX_FROM_NAME=Assistant

# Cloudflare Access service-token credentials (required).
CF_ACCESS_CLIENT_ID=your-service-token-client-id
CF_ACCESS_CLIENT_SECRET=your-service-token-secret

# Seconds between inbox polls (optional, default 20).
EMAIL_POLL_INTERVAL=20
